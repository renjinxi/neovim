# Python 路径配置
NVIM_PYTHON3_HOST_PROG="/usr/local/bin/python3"

# Java/Android 开发配置
# JAVA_HOME 指向 JDK 安装路径
JAVA_HOME="/Library/Java/JavaVirtualMachines/jdk-17.jdk/Contents/Home"

# ANDROID_HOME 指向 Android SDK 路径
# macOS 通常在: ~/Library/Android/sdk
# Linux 通常在: ~/Android/Sdk
ANDROID_HOME="$HOME/Library/Android/sdk"

# macism 路径配置
MACISM_CMD="/opt/homebrew/bin/macism"

# Claude Code API 配置
# API 1 配置 (用于 gc1)
CLAUDE_API1_BASE_URL="https://api.anthropic.com"
CLAUDE_API1_TOKEN="your_token_1_here"

# API 2 配置 (用于 gc2)
CLAUDE_API2_BASE_URL="https://api.moonshot.cn/anthropic/"
CLAUDE_API2_TOKEN="your_token_2_here"
